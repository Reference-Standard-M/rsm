#!/bin/sh
#
# Package: Reference Standard M
# File:    snap/local/rsm.daemon
# Summary: Snap daemon script for rsm
#
# SPDX-FileCopyrightText:  © 2026 Fourth Watch Software LC
# SPDX-FileContributor:    David Wicksell <dlw@linux.com>
