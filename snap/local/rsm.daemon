# WITHOUT ANY WARRANTY; without even the implied warranty of
# MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE. See the GNU Affero
# General Public License for more details.
#
# You should have received a copy of the GNU Affero General Public License
# along with this program. If not, see https://www.gnu.org/licenses/.

mjobs=$(snapctl get max-jobs 2>/dev/null)
mjobs=${mjobs:-32}
gbuff=$(snapctl get global-buffers 2>/dev/null)
gbuff=${gbuff:-$((mjobs / 2))}
rbuff=$(snapctl get routine-buffers 2>/dev/null)
rbuff=${rbuff:-$((mjobs / 8))}
rsmdb="$(snapctl get database-file 2>/dev/null)"
rsmdb="${rsmdb:-$SNAP_COMMON/rsm.dat}"

exec $SNAP/usr/bin/rsm -j $mjobs -g $gbuff -r $rbuff -U "$rsmdb"

# ex: filetype=sh
